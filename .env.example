# Database Configuration
POSTGRES_DB=hochzeit_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# Backend Configuration
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/hochzeit_db

# Optional: Environment
ENVIRONMENT=development

# Gallery access password (used for password-based token login)
GALLERY_PASSWORD=your_gallery_password_here

# Object Storage (S3-compatible – Hetzner Object Storage)
S3_ENDPOINT=https://<region>.your-objectstorage.com
S3_ACCESS_KEY=your_access_key_here
S3_SECRET_KEY=your_secret_key_here
S3_BUCKET_NAME=your_bucket_name_here
S3_REGION=eu-central
